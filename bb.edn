{:paths ["."]
 :deps {io.github.babashka/tools.bbuild {:git/sha "4493ba83664bdbfcaf932845fbd2f2183cdb7c1d"}}
 :tasks {prep    {:task (exec 'equipment.lets/prep)}
         jank    {:task (exec 'equipment.lets/jank)}
         jepl    {:task (exec 'equipment.lets/jepl)}
         compile {:task (exec 'equipment.lets/compile-jank)}
         lets (let [[action] *command-line-args*]
                (exec (symbol "equipment.lets" action)))}}
